{
  "services": [
    {
      "name": "backend",
      "dockerfile": "backend/Dockerfile",
      "startCommand": "npm start",
      "environments": {
        "NODE_ENV": "production",
        "PORT": "$PORT"
      },
      "port": 3000
    },
    {
      "name": "ai-service",
      "dockerfile": "ai-service/Dockerfile",
      "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port 8000",
      "environments": {
        "PORT": "8000"
      },
      "port": 8000
    }
  ]
}
